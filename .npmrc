# Monorepo workspace configuration
# This ensures a single lock file at the root level
shared-workspace-lockfile=true

# Ensure optional dependencies are installed (needed for Rollup on Alpine)
enable-pre-post-scripts=true

# Disable Rollup binary
rollup_binary=false

# Hoist all dependencies to make them accessible to TypeScript
shamefully-hoist=true

# Use Chinese npm mirror for faster downloads
registry=https://registry.npmmirror.com

# Prevent pnpm from aborting module removal in non-TTY environments (e.g., Git hooks, CI)
confirm-modules-purge=false

# Allow build scripts for necessary dependencies
ignore-scripts=false
