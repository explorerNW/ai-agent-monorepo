{
  "name": "lang-chain-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for LangChain Graph with NestJS backend and React frontend",
  "scripts": {
    "build": "pnpm -r build",
    "start:server": "pnpm -F llm start:dev",
    "start:ui": "pnpm -F my-app dev",
    "build:micro:rabbit-mq": "pnpm --filter rabbit-mq run build",
    "start:micro:rabbit-mq": "pnpm --filter rabbit-mq run start:dev",
    "build:all-micro": "pnpm --filter './packages/back-end/micro-service/*' run build",
    "prepare": "husky",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "commitlint": "commitlint --edit",
    "lint-staged": "lint-staged",
    "docker:start": "./docker.sh start",
    "docker:start:dev": "./docker.sh start:dev",
    "docker:stop": "./docker.sh stop",
    "docker:restart": "./docker.sh restart",
    "docker:logs": "./docker.sh logs",
    "docker:build": "./docker.sh build",
    "docker:clean": "./docker.sh clean",
    "docker:status": "./docker.sh status"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.1.2",
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3"
  }
}
