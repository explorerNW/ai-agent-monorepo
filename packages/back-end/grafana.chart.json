{
  "dashboard": {
    "id": null,
    "title": "前端性能监控",
    "tags": ["performance", "frontend"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "FCP (首次内容绘制)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "SELECT timestamp, fcp FROM performance_db.performance_metrics WHERE $timeFilter AND fcp IS NOT NULL ORDER BY timestamp",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "毫秒",
            "min": 0
          }
        ]
      },
      {
        "id": 2,
        "title": "LCP (最大内容绘制)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "SELECT timestamp, lcp FROM performance_db.performance_metrics WHERE $timeFilter AND lcp IS NOT NULL ORDER BY timestamp",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "毫秒",
            "min": 0
          }
        ]
      },
      {
        "id": 3,
        "title": "CLS (累积布局偏移)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "SELECT timestamp, cls FROM performance_db.performance_metrics WHERE $timeFilter AND cls IS NOT NULL ORDER BY timestamp",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "",
            "min": 0
          }
        ]
      },
      {
        "id": 4,
        "title": "API 响应时间分布",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "SELECT timestamp, duration FROM performance_db.api_metrics WHERE $timeFilter ORDER BY timestamp",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "毫秒",
            "min": 0
          }
        ]
      },
      {
        "id": 5,
        "title": "页面性能汇总",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "SELECT pageUrl, avg(fcp) as avg_fcp, avg(lcp) as avg_lcp, avg(cls) as avg_cls, count(*) as total_records FROM performance_db.performance_metrics WHERE $timeFilter AND fcp IS NOT NULL AND lcp IS NOT NULL GROUP BY pageUrl ORDER BY avg_lcp DESC LIMIT 20",
            "format": "table",
            "refId": "A"
          }
        ]
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "refresh": "30s"
  }
}
