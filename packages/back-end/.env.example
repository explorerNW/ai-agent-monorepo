# Backend Environment Variables Template
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS configuration)
FRONT_END_URL=http://localhost:3001

# Dify Configuration (if using Dify AI platform)
DIFY_API_KEY=your-dify-api-key
DIFY_BASE_URL=http://localhost:8461/v1
DIFY_DATASET_ID=your-dataset-id
DIFY_DATASET_API_KEY=your-dataset-api-key

# GitHub Configuration (for PR/Issue comments)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-github-username

# AI Model Configuration (e.g., Qwen/DashScope)
DASHSCOPE_API_KEY=your-dashscope-api-key
AI_MODEL_NAME=qwen3.6-plus

# Add any other backend-specific environment variables below