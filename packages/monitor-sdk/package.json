{
  "name": "@explorernw/monitor-sdk",
  "version": "1.0.8",
  "description": "企业级前端监控 SDK，支持性能、错误、接口耗时自动采集",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "keywords": [
    "monitor",
    "sdk",
    "performance",
    "error-tracking"
  ],
  "license": "MIT",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "rm -rf dist && npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.1.0",
    "rollup": "^4.9.0",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3"
  }
}
